{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Meter",
  "version": "0.4.0",
  "identifier": "com.jinhaolab.agentmeter",
  "build": {
    "beforeDevCommand": "npm.cmd run frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run frontend:build",
    "frontendDist": "../dist-ui"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Agent Meter",
        "width": 330,
        "height": 146,
        "minWidth": 168,
        "minHeight": 48,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
